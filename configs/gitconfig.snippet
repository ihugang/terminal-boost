# ── terminal-boost: git delta ────────────────────────────────────────────────
# Paste this into your ~/.gitconfig

[core]
	pager = delta

[delta]
	side-by-side = true
	line-numbers = true

[interactive]
	diffFilter = delta --color-only
# ────────────────────────────────────────────────────────────────────────────
