# ── terminal-boost ──────────────────────────────────────────────────────────
# Paste this block into your ~/.zshrc

alias ls="eza --icons"
alias ll="eza -la --icons --git"
alias lt="eza --tree --level=2 --icons"
alias cat="bat --paging=never"

eval "$(zoxide init zsh)"   # smart cd — use: z <dirname>
eval "$(atuin init zsh)"    # better Ctrl+R history search

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
# ────────────────────────────────────────────────────────────────────────────
